<Window x:Class="FileSyncPro.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:FileSyncPro.Converters"
        xmlns:vm="clr-namespace:FileSyncPro.ViewModels"
        xmlns:models="clr-namespace:FileSyncPro.Models"
        xmlns:local="clr-namespace:FileSyncPro.Utilities"
        Title="Petrofac FileSyncPro - Advanced File Synchronization"
        Background="#F5F7FA"
        Icon="/app.ico"
        MinHeight="540" MinWidth="750">


    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:LogLevelToColorConverter x:Key="LogLevelToColor"/>

        <!-- Modern Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#6C757D"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5A6268"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Success Button Style -->
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#28A745"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#218838"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#0078D7"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#F3F4F6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern ComboBox Style -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- Modern GroupBox Style -->
        <Style x:Key="ModernGroupBox" TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Border Background="White"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="#F9FAFB"
                                            CornerRadius="6,6,0,0"
                                            Padding="12,8">
                                        <ContentPresenter ContentSource="Header"
                                                         TextBlock.FontWeight="SemiBold"
                                                         TextBlock.FontSize="14"
                                                         TextBlock.Foreground="#374151"/>
                                    </Border>
                                    <ContentPresenter Grid.Row="1" Margin="{TemplateBinding Padding}"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <!-- Main Content with ScrollViewer -->
            <RowDefinition Height="Auto"/>
            <!-- Footer Buttons -->
        </Grid.RowDefinitions>

        <!-- Main Content Area with ScrollViewer -->
        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Header -->
                    <RowDefinition Height="Auto"/>
                    <!-- Source Configuration -->
                    <RowDefinition Height="Auto"/>
                    <!-- Destination Configuration -->
                    <RowDefinition Height="Auto"/>
                    <!-- Progress and Logs -->
                </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White"
                CornerRadius="8"
                Padding="20"
                Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.1" BlurRadius="10" ShadowDepth="0"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <Image Grid.Row="0" Grid.Column="0"
                       Source="/logo.jpg"
                       Width="48"
                       Height="48"
                       Margin="0,0,15,0"
                       VerticalAlignment="Top"
                       Stretch="Uniform"/>

                <!-- Title Section -->
                <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Petrofac "
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#111827"/>
                        <TextBlock Text="FileSyncPro"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#111827"/>
                    </StackPanel>
                    <TextBlock Text="Advanced File Synchronization Tool"
                               FontSize="13"
                               Foreground="#6B7280"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Welcome Section -->
                <Border Grid.Row="1" Grid.Column="1"
                        Background="#F0F9FF"
                        BorderBrush="#3B82F6"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12,8"
                        Margin="0,15,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="Welcome, "
                                       FontSize="12"
                                       Foreground="#1E40AF"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CurrentUserName}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#1E40AF"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text=" | "
                                       FontSize="12"
                                       Foreground="#1E40AF"
                                       Margin="8,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CurrentDate}"
                                       FontSize="12"
                                       Foreground="#1E40AF"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Source Configuration - Always Visible -->
        <GroupBox Grid.Row="1" Header="Source Configuration" Style="{StaticResource ModernGroupBox}">
                    <StackPanel>
                        <!-- Source Type Selection -->
                        <TextBlock Text="Select source type"
                                   Foreground="#6B7280"
                                   FontSize="12"
                                   Margin="0,0,0,8"/>

                        <ComboBox SelectedValue="{Binding SelectedSourceType}"
                                  SelectedValuePath="Content"
                                  Style="{StaticResource ModernComboBox}"
                                  Height="38"
                                  Margin="0,0,0,15">
                            <ComboBoxItem Content="Local" IsSelected="True"/>
                            <ComboBoxItem Content="SharePoint"/>
                            <ComboBoxItem Content="SFTP"/>
                        </ComboBox>

                        <!-- Local Source Configuration -->
                        <StackPanel Visibility="{Binding IsSourceLocal, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Select folder containing files"
                                       Foreground="#6B7280"
                                       FontSize="12"
                                       Margin="0,0,0,8"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         Text="{Binding SourcePath, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}"
                                         Margin="0,0,10,0"
                                         Height="38"/>

                                <Button Grid.Column="1"
                                        Content="Browse"
                                        Command="{Binding BrowseSourceCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Width="100"
                                        Height="38"/>
                            </Grid>
                        </StackPanel>

                        <!-- SharePoint Source Configuration -->
                        <StackPanel Visibility="{Binding IsSourceSharePoint, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="SharePoint URL (paste from browser)"
                                       Foreground="#6B7280"
                                       FontSize="12"
                                       Margin="0,0,0,8"/>

                            <TextBox Text="{Binding SourceConfig.SharePointUrl, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"
                                     Height="38"
                                     ToolTip="Example: https://yourcompany.sharepoint.com/sites/yoursite/Shared Documents/Folder"/>
                        </StackPanel>

                        <!-- SFTP Source Configuration -->
                        <Grid Visibility="{Binding IsSourceSFTP, Converter={StaticResource BoolToVisibility}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                                <TextBlock Text="Host *" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding SourceConfig.SFTPHost, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}" Height="38"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,10">
                                <TextBlock Text="Port *" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding SourceConfig.SFTPPort, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}" Height="38"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,10">
                                <TextBlock Text="Username *" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding SourceConfig.SFTPUser, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}" Height="38"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,10">
                                <TextBlock Text="Password *" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,8"/>
                                <PasswordBox x:Name="txtSourceSFTPPassword"
                                             local:PasswordHelper.Attach="True"
                                             local:PasswordHelper.Password="{Binding SourceConfig.SFTPPassword, Mode=TwoWay}"
                                             Height="38"
                                             Padding="10,8"
                                             BorderBrush="#D1D5DB"
                                             BorderThickness="1"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,10">
                                <TextBlock Text="Remote Path *" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding SourceConfig.SFTPPath, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ModernTextBox}" Height="38"
                                             Margin="0,0,10,0"
                                             ToolTip="Example: /data/files"/>
                                    <Button Grid.Column="1"
                                            Content="Browse"
                                            Command="{Binding BrowseSFTPSourceCommand}"
                                            Style="{StaticResource SecondaryButton}"
                                            Width="100" Height="38"/>
                                </Grid>
                            </StackPanel>

                            <!-- Row 3: Remember Source Credentials -->
                            <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                                <CheckBox IsChecked="{Binding RememberSourceSftpCredentials, Mode=TwoWay}" FontSize="12" Foreground="#374151" VerticalAlignment="Center"/>
                                <TextBlock Text="Save SFTP source user/password for next use" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="#374151" FontSize="12"/>
                            </StackPanel>
                        </Grid>

                        <!-- Validation Messages -->
                        <StackPanel Margin="0,10,0,0">
                            <Border Background="#EFF6FF"
                                    BorderBrush="#3B82F6"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="10"
                                    Visibility="{Binding HasZipFiles, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✓"
                                               Foreground="#3B82F6"
                                               FontWeight="Bold"
                                               FontSize="14"
                                               Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding ZipFilesInfo}"
                                               Foreground="#1E40AF"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>

                            <!-- Error border - only for non-SharePoint destinations without ZIP files -->
                            <Border Background="#FEF2F2"
                                    BorderBrush="#EF4444"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="10"
                                    Visibility="{Binding HasSourceValidationError, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚠"
                                               Foreground="#EF4444"
                                               FontWeight="Bold"
                                               FontSize="14"
                                               Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding ZipFilesInfo}"
                                               Foreground="#991B1B"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>

                            <!-- Info border - for SharePoint without ZIP files -->
                            <Border Background="#EFF6FF"
                                    BorderBrush="#3B82F6"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="10"
                                    Visibility="{Binding HasZipFiles, Converter={StaticResource BoolToVisibility}, ConverterParameter=inverse}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasSourceValidationError}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="ℹ"
                                               Foreground="#3B82F6"
                                               FontWeight="Bold"
                                               FontSize="14"
                                               Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding ZipFilesInfo}"
                                               Foreground="#1E40AF"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

        <!-- Destination Configuration - Always Visible -->
        <GroupBox Grid.Row="2" Header="Destination Configuration" Style="{StaticResource ModernGroupBox}">
                    <StackPanel>
                        <TextBlock Text="Select destination type"
                                   Foreground="#6B7280"
                                   FontSize="12"
                                   Margin="0,0,0,8"/>

                        <ComboBox SelectedValue="{Binding SelectedDestinationType}"
                                  SelectedValuePath="Content"
                                  Style="{StaticResource ModernComboBox}"
                                  Height="38"
                                  Margin="0,0,0,15">
                            <ComboBoxItem Content="Local"/>
                            <ComboBoxItem Content="SharePoint"/>
                            <ComboBoxItem Content="SFTP"/>
                        </ComboBox>

                        <!-- Local Destination -->
                        <StackPanel Visibility="{Binding SelectedDestinationType, Converter={StaticResource BoolToVisibility}, ConverterParameter=Local}">
                            <TextBlock Text="Local Folder Path"
                                       FontWeight="SemiBold"
                                       Foreground="#374151"
                                       Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding DestinationConfig.LocalPath, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}"
                                         Height="38"
                                         Margin="0,0,10,0"/>
                                <Button Grid.Column="1"
                                        Content="Browse"
                                        Command="{Binding BrowseLocalCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Width="100"
                                        Height="38"/>
                            </Grid>
                        </StackPanel>

                        <!-- SharePoint Destination -->
                        <Grid Visibility="{Binding SelectedDestinationType, Converter={StaticResource BoolToVisibility}, ConverterParameter=SharePoint}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Info Banner -->
                            <Border Grid.Row="0"
                                    Background="#ECFDF5"
                                    BorderBrush="#10B981"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="12"
                                    Margin="0,0,0,15">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="ℹ"
                                               Foreground="#10B981"
                                               FontWeight="Bold"
                                               FontSize="14"
                                               Margin="0,0,10,0"/>
                                    <TextBlock Text="Using interactive browser authentication - you'll be prompted to sign in with your Microsoft 365 account"
                                               Foreground="#065F46"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="SharePoint Site URL *"
                                               FontWeight="SemiBold"
                                               Foreground="#374151"
                                               Margin="0,0,0,8"/>
                                    <TextBox Text="{Binding DestinationConfig.SharePointUrl, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ModernTextBox}"
                                             Height="38"
                                             ToolTip="Example: https://yourcompany.sharepoint.com/sites/YourSite/Shared Documents/Folder"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Document Library"
                                               FontWeight="SemiBold"
                                               Foreground="#374151"
                                               Margin="0,0,0,8"/>
                                    <TextBox Text="{Binding DestinationConfig.SharePointLibrary, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ModernTextBox}"
                                             Height="38"
                                             ToolTip="Optional - Leave empty to auto-detect from URL"/>
                                </StackPanel>
                            </Grid>

                            <!-- Help Text -->
                            <TextBlock Grid.Row="2"
                                       Text="Tip: You can paste the full SharePoint URL including folder path, and it will be parsed automatically"
                                       Foreground="#6B7280"
                                       FontSize="11"
                                       FontStyle="Italic"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <!-- SFTP Destination -->
                        <Grid Visibility="{Binding SelectedDestinationType, Converter={StaticResource BoolToVisibility}, ConverterParameter=SFTP}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Row 0: Host & Port -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                                <TextBlock Text="Host *" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding DestinationConfig.SFTPHost, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}" Height="38"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,10">
                                <TextBlock Text="Port *" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding DestinationConfig.SFTPPort, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}" Height="38"/>
                            </StackPanel>

                            <!-- Row 1: Username & Password -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,10">
                                <TextBlock Text="Username *" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding DestinationConfig.SFTPUser, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}" Height="38"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,10">
                                <TextBlock Text="Password *" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,8"/>
                                <PasswordBox x:Name="txtSFTPPassword"
                                             local:PasswordHelper.Attach="True"
                                             local:PasswordHelper.Password="{Binding DestinationConfig.SFTPPassword, Mode=TwoWay}"
                                             Height="38"
                                             Padding="10,8"
                                             BorderBrush="#D1D5DB"
                                             BorderThickness="1"/>
                            </StackPanel>

                            <!-- Row 2: Remote Path -->
                            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,10">
                                <TextBlock Text="Remote Path *" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding DestinationConfig.SFTPPath, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}" Height="38"/>
                            </StackPanel>
                            <!-- Row 3: Remember Destination Credentials -->
                            <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                                <CheckBox IsChecked="{Binding RememberDestinationSftpCredentials, Mode=TwoWay}" FontSize="12" Foreground="#374151" VerticalAlignment="Center"/>
                                <TextBlock Text="Save SFTP destination user/password for next use" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="#374151" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </GroupBox>

        <!-- Progress and Logs -->
        <GroupBox Grid.Row="3" Header="Progress and Logs" Style="{StaticResource ModernGroupBox}" Margin="0,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="150"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Progress Bar -->
                        <Grid Grid.Row="0" Margin="0,0,0,15">
                            <StackPanel>
                                <!-- Full-width status line above the bar so long text is never clipped -->
                                <TextBlock Text="{Binding Progress.CurrentOperation}"
                                           FontStyle="Italic"
                                           Foreground="#6B7280"
                                           FontSize="12"
                                           Margin="0,0,0,6"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"/>

                                <ProgressBar Height="8"
                                             IsIndeterminate="True"
                                             Visibility="{Binding IsOperationRunning, Converter={StaticResource BoolToVisibility}}"
                                             Background="#E5E7EB"
                                             Foreground="#0078D7"
                                             BorderThickness="0"
                                             Margin="0,0,0,6"/>

                                <ProgressBar Value="{Binding Progress.Percentage}"
                                             Height="32"
                                             Background="#F3F4F6"
                                             Foreground="#0078D7"
                                             BorderThickness="0"
                                             Minimum="0"
                                             Maximum="100"
                                             IsEnabled="False">
                                    <ProgressBar.Resources>
                                        <Style TargetType="ProgressBar">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ProgressBar">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="8"
                                                                BorderThickness="0">
                                                            <Grid>
                                                                <Border x:Name="PART_Track" CornerRadius="8"/>
                                                                <Border x:Name="PART_Indicator"
                                                                        HorizontalAlignment="Left"
                                                                        Background="{TemplateBinding Foreground}"
                                                                        CornerRadius="8"/>
                                                                <TextBlock Text="{Binding Progress.Percentage, StringFormat={}{0:0}%}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#374151"/>
                                                            </Grid>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ProgressBar.Resources>
                                </ProgressBar>
                            </StackPanel>
                        </Grid>

                        <!-- Log List -->
                        <Border Grid.Row="1"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="4"
                                Background="White">
                            <ListBox x:Name="LogListBox"
                                     ItemsSource="{Binding Progress.LogEntries}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,4"
                                                Margin="0,1"
                                                CornerRadius="2">
                                            <TextBlock Text="{Binding Message}"
                                                       TextWrapping="Wrap"
                                                       FontSize="12"
                                                       FontFamily="Consolas">
                                                <TextBlock.Foreground>
                                                    <Binding Path="Level" Converter="{StaticResource LogLevelToColor}"/>
                                                </TextBlock.Foreground>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <!-- Log Controls -->
                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Left"
                                    Margin="0,15,0,0">
                            <Button Content="Clear Log"
                                    Command="{Binding ClearLogCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Width="100"
                                    Height="34"
                                    Margin="0,0,10,0"/>
                            <Button Content="Export Log"
                                    Command="{Binding ExportLogCommand}"
                                    Style="{StaticResource SuccessButton}"
                                    Width="100"
                                    Height="34"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>
            </Grid>
        </ScrollViewer>

        <!-- Footer Actions - Always Fixed at Bottom -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                Padding="20"
                Margin="0,20,0,0">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.1" BlurRadius="10" ShadowDepth="0"/>
            </Border.Effect>
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="Reset"
                            Command="{Binding ResetCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Width="120"
                            Height="42"
                            FontSize="14"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Process Files"
                            Command="{Binding ProcessCommand}"
                            Style="{StaticResource ModernButton}"
                            Width="150"
                            Height="42"
                            FontSize="14"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
