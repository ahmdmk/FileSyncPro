<Window x:Class="FileSyncPro.Views.SFTPBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Browse SFTP Folders"
        Height="540" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F5F7FA">

    <Window.Resources>
        <Style x:Key="BrowserButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Select Remote Folder"
                   FontSize="16"
                   FontWeight="Bold"
                   Foreground="#111827"
                   Margin="0,0,0,4"/>

        <TextBlock Grid.Row="1"
                   x:Name="HostLabel"
                   FontSize="12"
                   Foreground="#6B7280"
                   Margin="0,0,0,15"/>

        <!-- Folder TreeView -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="6">
            <TreeView x:Name="FolderTree"
                      BorderThickness="0"
                      Background="Transparent"
                      FontSize="13"
                      Padding="4"
                      SelectedItemChanged="FolderTree_SelectedItemChanged"/>
        </Border>

        <!-- Selected Path Display -->
        <StackPanel Grid.Row="3" Margin="0,12,0,12">
            <TextBlock Text="Selected Path:"
                       FontWeight="SemiBold"
                       FontSize="12"
                       Foreground="#374151"
                       Margin="0,0,0,4"/>
            <Border Background="White"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="10,8">
                <TextBlock x:Name="SelectedPathBox"
                           Text="/"
                           FontSize="12"
                           Foreground="#374151"
                           FontFamily="Consolas"/>
            </Border>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Width="90" Height="36"
                    Margin="0,0,10,0"
                    Background="#6C757D"
                    Style="{StaticResource BrowserButton}"
                    Click="Cancel_Click"/>
            <Button Content="Select Folder"
                    Width="120" Height="36"
                    Background="#0078D7"
                    Style="{StaticResource BrowserButton}"
                    Click="Select_Click"/>
        </StackPanel>
    </Grid>
</Window>
